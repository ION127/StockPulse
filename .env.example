# ── AI / 뉴스 (필수) ──────────────────────────────────────────────────────────
# Groq API Key (무료, 14,400 RPD) - https://console.groq.com 에서 발급
GROQ_API_KEY=your_groq_api_key_here

# NewsAPI Key (영문 뉴스) - https://newsapi.org 에서 무료 발급
NEWS_API_KEY=your_newsapi_key_here

# ── 한국투자증권 KIS (한국 주식 실시간 연동 시 필요) ──────────────────────────
# https://apiportal.koreainvestment.com → 내 앱 → 앱 등록
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_MOCK=false   # 모의투자 테스트 시 true

# ── Slack 알림 (선택) ─────────────────────────────────────────────────────────
# Slack Incoming Webhook URL - 설정하지 않으면 로그로만 출력
SLACK_WEBHOOK_URL=

# ── 이상값 탐지 임계값 ────────────────────────────────────────────────────────
ANOMALY_THRESHOLD_PERCENT=1.5   # 1분봉 기준 1.5% 이상 변동 (일봉 사용 시 7.5 권장)
ANOMALY_ZSCORE_THRESHOLD=3.0    # Z-score 기준

# ── 스케줄 / 수집 설정 ────────────────────────────────────────────────────────
SCHEDULE_INTERVAL_MINUTES=60    # APScheduler fallback 실행 주기 (분)
COLLECT_INTERVAL_SECONDS=60     # stock-collector 수집 주기 (초)
INTRADAY_RECENT_MINUTES=5       # 장중 최근 N분 이내 bar만 이상값으로 처리

# ── 알림 필터 (선택) ──────────────────────────────────────────────────────────
NOTIFY_SECTORS=                           # 빈 값 = 전체 섹터 허용 (예: 반도체,금융)
NOTIFY_EVENT_TYPES=INDIVIDUAL,SECTOR,MARKET
