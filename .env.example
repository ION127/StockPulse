# Gemini API Key (무료) - https://aistudio.google.com 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# NewsAPI Key (영문 뉴스) - https://newsapi.org 에서 무료 발급
NEWS_API_KEY=your_newsapi_key_here

# 이상값 탐지 임계값 설정
ANOMALY_THRESHOLD_PERCENT=5.0   # 5% 이상 변동시 이상값으로 판단
ANOMALY_ZSCORE_THRESHOLD=2.5    # Z-score 기준

# 스케줄 설정 (cron 형식)
SCHEDULE_INTERVAL_MINUTES=60    # 60분마다 실행
